{
  "route": {
    "default_domain_resolver": "local-dns",
    "auto_detect_interface": true,
    "final": "Final",
    "default_mark": 255,
    "rules": [
  /*{
    "inbound": "dns-in",
    "action": "hijack-dns"
  },*/
  {
    "inbound": "fake-in",
    "action": "hijack-dns"
  },
  {
    "ip_cidr": [
      "223.5.5.5/32"
    ],
    "outbound": "direct"
  },
  {
    "ip_cidr": [
      "1.1.1.1/32",
      "1.0.0.1/32",
      "8.8.8.8/32",
      "8.8.4.4/32"
    ],
    "outbound": "Proxy"
  },
  {
    "type": "logical",
    "mode": "or",
    "rules": [
      {
        "network": "udp",
        "port": 443
      },
      {
        "protocol": "stun"
      }
    ],
    "action": "reject",
    "method": "drop"
  },
  {
    "rule_set": [
      "geosite-youtube"
    ],
    "outbound": "YouTube"
  },
  {
    "rule_set": [
      "geosite-openai",
      "geosite-gemini",
      "geosite-anthropic",
      "geosite-category-ai-!cn",
      "geosite-category-ai-chat-!cn",
      "geosite-xai",
      "geosite-meta-ai",
      "geosite-jetbrains-ai"
    ],
    "outbound": "AI"
  },
  {
    "rule_set": [
      "geosite-github",
      "geosite-jetbrains"
    ],
    "outbound": "GitHub"
  },
  {
    "rule_set": [
      "geosite-speedtest"
    ],
    "outbound": "Speedtest"
  },
  {
    "rule_set": [
      "geoip-telegram",
      "geosite-telegram"
    ],
    "outbound": "Telegram"
  },
  {
    "rule_set": [
      "geosite-google",
      "geosite-spotify",
      "geosite-facebook",
      "geosite-instagram",
      "geosite-tiktok"
    ],
    "outbound": "Proxy"
  },
  {
    "ip_is_private": true,
    "outbound": "direct"
  }
],
    "rule_set": [
      {
        "type": "local",
        "format": "binary",
        "tag": "geosite-google",
        "path": "/usr/local/etc/sing-box/rules/geosite/google.srs"
      },
      {
        "type": "local",
        "format": "binary",
        "tag": "geosite-youtube",
        "path": "/usr/local/etc/sing-box/rules/geosite/youtube.srs"
      },
      {
        "type": "local",
        "format": "binary",
        "tag": "geosite-speedtest",
        "path": "/usr/local/etc/sing-box/rules/geosite/speedtest.srs"
      },
      {
        "type": "local",
        "format": "binary",
        "tag": "geosite-openai",
        "path": "/usr/local/etc/sing-box/rules/geosite/openai.srs"
      },
      {
        "type": "local",
        "format": "binary",
        "tag": "geosite-gemini",
        "path": "/usr/local/etc/sing-box/rules/geosite/google-gemini.srs"
      },
      {
        "type": "local",
        "format": "binary",
        "tag": "geosite-telegram",
        "path": "/usr/local/etc/sing-box/rules/geosite/telegram.srs"
      },
      {
